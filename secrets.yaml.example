# =============================================================================
# secrets.yaml — ESPHome secrets for WalkieClaw
# =============================================================================
# Copy this file to secrets.yaml and fill in your values.
# NEVER commit secrets.yaml to version control!
#
# All fields are required unless marked optional.
# =============================================================================

# Your home WiFi network
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Phone hotspot (optional — for on-the-go use)
hotspot_ssid: "YOUR_HOTSPOT_SSID"
hotspot_password: "YOUR_HOTSPOT_PASSWORD"

# Fallback AP password (used if WiFi fails, device creates its own AP)
fallback_password: "12345678"

# ESPHome API encryption key (generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())")
api_encryption_key: "GENERATE_A_BASE64_KEY_HERE"

# ESPHome OTA password
ota_password: "YOUR_OTA_PASSWORD"

# Bridge API key is now configured at runtime via the ESP32's web UI.
# No need to set it here — visit http://<device_ip>/ after flashing.
