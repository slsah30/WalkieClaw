# AIPI Bridge Configuration
# Copy this to .env and fill in your values

# ESP32 IP (auto-discovered via UDP relay, but set a default)
ESPHOME_HOST=192.168.1.50

# IP that ESP32 uses to reach this bridge's HTTP server
# (e.g., your relay machine's LAN IP if port-forwarding)
HTTP_ADVERTISE_HOST=

# Whisper STT model: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# TTS engine: gtts, edge, elevenlabs
TTS_ENGINE=edge
EDGE_TTS_VOICE=en-GB-RyanNeural

# ESPHome API encryption key (from your secrets.yaml)
ESPHOME_NOISE_PSK=

# OpenClaw agent gateway
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_MODE=chat
