# =============================================================================
# WalkieClaw Bridge — Configuration
# =============================================================================
# Copy this to .env in the same directory as bridge.py.
#
# Works for both local (PC on your LAN) and VPS (remote server) deployments.
# The ESP32 sends audio over UDP and polls for responses over HTTP.
# Firewall must allow inbound UDP:12345 and TCP:8080.
# =============================================================================

# --- Network ---
# Bind addresses — 0.0.0.0 listens on all interfaces
UDP_HOST=0.0.0.0
UDP_PORT=12345
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# The IP the ESP32 uses to fetch WAV files from this bridge.
# For VPS: your server's public IP
# For local: your PC's LAN IP (find with ipconfig / ip addr)
HTTP_ADVERTISE_HOST=<YOUR_IP>

# --- ESPHome Device (optional) ---
# Only needed if you want the bridge to push updates via the ESPHome native API.
# Usually left blank — the ESP32 polls the bridge instead.
ESPHOME_HOST=
ESPHOME_PORT=6053
ESPHOME_PASSWORD=
ESPHOME_NOISE_PSK=

# --- OpenClaw Gateway ---
# OpenClaw provides the AI agent. Use loopback if running on the same machine.
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=<YOUR_OPENCLAW_TOKEN>
# Mode: "chat" for conversational responses
OPENCLAW_MODE=chat

# --- Speech-to-Text ---
# Whisper model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower. "small" is a good balance.
WHISPER_MODEL=small
# Language code (e.g., en, es, fr, de, ja)
WHISPER_LANGUAGE=en
# Device: "cpu" or "cuda" (NVIDIA GPU with CUDA toolkit required for cuda)
WHISPER_DEVICE=cpu

# --- Text-to-Speech ---
# Engine: edge (free, high quality), gtts (free, basic), elevenlabs (paid, premium)
TTS_ENGINE=edge
# Edge TTS voice — see https://github.com/rany2/edge-tts for full list
EDGE_TTS_VOICE=en-GB-RyanNeural
# Only needed if TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Security ---
# Shared secret between ESP32 and bridge. Must match the API key configured on
# the device (set via the web UI at http://<device_ip>/).
BRIDGE_API_KEY=<YOUR_BRIDGE_API_KEY>

# --- Audio ---
# Directory for temporary WAV files. Cleaned up automatically.
AUDIO_DIR=/tmp/walkieclaw-audio
