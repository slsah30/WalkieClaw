# =============================================================================
# WalkieClaw Bridge — LOCAL MODE (bridge.py runs on your PC)
# =============================================================================
# Copy this to .env in the same directory as bridge.py.
#
# In local mode, both bridge.py and OpenClaw run on your PC.
# The ESP32 sends audio to your PC's LAN IP over UDP.
# =============================================================================

# --- Network ---
UDP_HOST=0.0.0.0
UDP_PORT=12345
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Your PC's LAN IP — the ESP32 fetches WAV files from this address
# Find it with: ipconfig (Windows) or ip addr (Linux)
HTTP_ADVERTISE_HOST=<YOUR_PC_LAN_IP>

# --- ESPHome Device (optional — for push notifications) ---
# Set to ESP32's IP if you want bridge to push updates via ESPHome API
ESPHOME_HOST=
ESPHOME_PORT=6053
ESPHOME_PASSWORD=
ESPHOME_NOISE_PSK=

# --- OpenClaw Gateway ---
# OpenClaw runs locally — use loopback
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=<YOUR_OPENCLAW_TOKEN>
OPENCLAW_MODE=chat

# --- Speech-to-Text ---
# Models: tiny, base, small, medium, large-v3
# Use "small" for good accuracy, "base" for faster on weaker hardware
WHISPER_MODEL=small
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu

# --- Text-to-Speech ---
# Engines: edge, gtts, elevenlabs
TTS_ENGINE=edge
EDGE_TTS_VOICE=en-GB-RyanNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Security ---
# Must match bridge_api_key in your ESPHome secrets.yaml
BRIDGE_API_KEY=<YOUR_BRIDGE_API_KEY>

# --- Audio ---
AUDIO_DIR=./audio
