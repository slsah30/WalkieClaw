# =============================================================================
# WalkieClaw Bridge — VPS MODE (bridge.py runs on a remote server)
# =============================================================================
# Copy this to .env in /opt/walkieclaw-bridge/ on your VPS.
#
# In VPS mode, bridge.py and OpenClaw run on a remote server.
# The ESP32 sends audio directly to the VPS public IP over UDP.
# Firewall must allow inbound UDP:12345 and TCP:8080.
# =============================================================================

# --- Network ---
UDP_HOST=0.0.0.0
UDP_PORT=12345
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Your VPS's public IP — the ESP32 fetches WAV files from this address
HTTP_ADVERTISE_HOST=<YOUR_VPS_PUBLIC_IP>

# --- ESPHome Device (optional — usually unreachable from VPS) ---
ESPHOME_HOST=
ESPHOME_PORT=6053
ESPHOME_PASSWORD=
ESPHOME_NOISE_PSK=

# --- OpenClaw Gateway ---
# OpenClaw runs on same VPS — use loopback
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=<YOUR_OPENCLAW_TOKEN>
OPENCLAW_MODE=chat

# --- Speech-to-Text ---
# Models: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu

# --- Text-to-Speech ---
# Engines: edge, gtts, elevenlabs
TTS_ENGINE=edge
EDGE_TTS_VOICE=en-GB-RyanNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Security ---
# Must match bridge_api_key in your ESPHome secrets.yaml
BRIDGE_API_KEY=<YOUR_BRIDGE_API_KEY>

# --- Audio ---
AUDIO_DIR=/tmp/walkieclaw-audio
